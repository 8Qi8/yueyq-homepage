<section class="card overflow-hidden flex flex-col">
  <!-- 聊天头部：简化为一行，去客服感 -->
  <div
    class="flex items-center gap-2.5 px-5 py-3.5
           border-b border-brand-border/50
           max-sm:px-4 max-sm:py-3"
  >
    <div
      class="w-3.5 h-3.5 rounded-full ai-gradient flex-shrink-0"
    ></div>
    <span class="text-sm font-medium text-brand-text tracking-wide">
      数字分身
    </span>
    <span class="text-[11px] text-brand-text-muted ml-auto">
      问我任何问题
    </span>
  </div>

  <!-- 消息列表 -->
  <div
    id="chatMessages"
    class="chat-scroll flex-1 min-h-[120px] max-h-[360px] overflow-y-auto
           flex flex-col gap-3.5 px-4 py-[18px] bg-[#fcfdfe]
           max-sm:max-h-[280px] max-sm:px-3 max-sm:py-3.5 max-sm:gap-2.5
           max-[360px]:max-h-[240px]"
  >
    <div class="flex gap-2.5">
      <div
        class="ai-gradient w-8 h-8 rounded-full flex items-center justify-center
               text-xs font-bold text-white select-none flex-shrink-0"
      >
        AI
      </div>
      <div class="bubble-ai">
        <p>你好！我是 yueyq 的数字分身&ensp;👋</p>
        <p class="mt-1.5">
          我正在学习 AI Agent 和 Vibe Coding，也在做一些科研任务。有什么想聊的吗？
          可以问我问题，或者点击下面的快捷提问~
        </p>
      </div>
    </div>
  </div>

  <!-- 预设问题 -->
  <div
    id="presetQuestions"
    class="flex flex-wrap gap-2 px-4 py-3
           border-t border-brand-border/40
           max-sm:px-3 max-sm:py-2.5 max-sm:gap-1.5"
  >
    <button
      class="preset-chip"
      data-question="你为什么这么注重细节？"
    >你为什么这么注重细节？</button>
    <button
      class="preset-chip"
      data-question="你怎么这么有耐心？"
    >你怎么这么有耐心？</button>
    <button
      class="preset-chip"
      data-question="你为什么总喜欢把问题研究得这么透？"
    >为什么研究得这么透？</button>
  </div>

  <!-- 输入区域 -->
  <div
    class="flex gap-2.5 px-4 py-3 border-t border-brand-border/40
           max-sm:px-3 max-sm:py-2.5 max-sm:gap-2"
  >
    <input
      type="text"
      id="chatInput"
      class="flex-1 min-w-0 px-4 py-[11px] text-sm font-sans
             text-brand-text bg-[#f6f9fb] border border-[#e0eaf2]
             rounded-[24px] outline-none
             placeholder-[#a8bfcc]
             transition-all duration-200
             focus:border-[#8abcd5] focus:bg-white focus:shadow-[0_0_0_3px_rgba(138,188,213,0.12)]
             max-sm:px-3.5 max-sm:py-2.5 max-sm:text-[13.5px] max-sm:rounded-[20px]"
      placeholder="输入你的问题..."
      autocomplete="off"
    />
    <button
      id="sendBtn"
      class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0
             ai-gradient text-white cursor-pointer
             transition-all duration-200
             shadow-[0_3px_10px_rgba(74,141,181,0.25)]
             hover:-translate-y-0.5 hover:shadow-[0_5px_16px_rgba(74,141,181,0.35)]
             active:scale-95 active:shadow-[0_2px_6px_rgba(74,141,181,0.3)]
             disabled:opacity-55 disabled:cursor-not-allowed disabled:translate-y-0
             disabled:shadow-none
             max-sm:w-10 max-sm:h-10"
      aria-label="发送消息"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="max-sm:w-[17px] max-sm:h-[17px]"
      >
        <line x1="22" y1="2" x2="11" y2="13"></line>
        <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
      </svg>
    </button>
  </div>
</section>

<script>
  import { initChat } from "../lib/chat";
  initChat();
</script>
