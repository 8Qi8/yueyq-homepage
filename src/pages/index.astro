---
import "../styles/global.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProfileHeader from "../components/ProfileHeader.astro";
import InfoCard from "../components/InfoCard.astro";
import Timeline from "../components/Timeline.astro";
import Footer from "../components/Footer.astro";
import PortfolioDrawer from "../components/PortfolioDrawer.astro";
import ChatSection from "../components/ChatSection.astro";
---

<BaseLayout
  title="yueyq · 个人主页"
  description="yueyq 的个人主页——AI Agent 学习者、软件工程硕士、数字分身聊天"
>
  <ProfileHeader />

  <hr class="border-[#c2cdd7] mx-2" />

  <InfoCard />

  <hr class="border-[#c2cdd7] mx-2" />

  <Timeline />

  <hr class="border-[#c2cdd7] mx-2" />

  <Footer />

  <!-- 数字分身：fixed 定位，不占页面流 -->
  <ChatSection />

  <!-- 作品展示：左侧竖式按钮 + 抽屉面板 -->
  <PortfolioDrawer />
</BaseLayout>
